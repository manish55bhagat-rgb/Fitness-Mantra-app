rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Globally accessible helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Auth-owned validation
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'manish55bhagat@gmail.com' || (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        )
      );
    }

    // Validation helpers
    function isValidUserProfile(data, isCreate) {
      return (
        (!isCreate || (data.keys().hasAll(['fullName', 'email', 'uid', 'role', 'registrationDate', 'lastLogin']))) &&
        data.keys().size() <= 20 &&
        (!('fullName' in data) || (data.fullName is string && data.fullName.size() <= 100)) &&
        (!('email' in data) || (data.email is string && data.email.size() <= 100)) &&
        (!('uid' in data) || (data.uid is string && data.uid.size() <= 128)) &&
        (!('role' in data) || (data.role is string && (data.role == 'admin' || data.role == 'user'))) &&
        (!('registrationDate' in data) || (data.registrationDate is string)) &&
        (!('lastLogin' in data) || (data.lastLogin is string)) &&
        (!('profilePhotoUrl' in data) || (data.profilePhotoUrl is string)) &&
        (!('photoUrl' in data) || (data.photoUrl is string)) &&
        (!('isOnline' in data) || (data.isOnline is bool)) &&
        (!('age' in data) || (data.age is number)) &&
        (!('gender' in data) || (data.gender is string)) &&
        (!('height' in data) || (data.height is number)) &&
        (!('weight' in data) || (data.weight is number)) &&
        (!('subscriptionStatus' in data) || (data.subscriptionStatus is string)) &&
        (!('subscriptionExpiry' in data) || (data.subscriptionExpiry is string))
      );
    }

    function isValidWorkout(data) {
      return data.keys().hasAll(['workoutName', 'duration', 'caloriesBurned', 'completed', 'userId', 'timestamp'])
          && data.keys().size() == 6
          && data.workoutName is string && data.workoutName.size() <= 100
          && data.duration is number
          && data.caloriesBurned is number
          && data.completed is bool
          && data.userId is string
          && (data.timestamp is string || data.timestamp is timestamp);
    }

    function isValidDiet(data) {
      return data.keys().hasAll(['mealName', 'calories', 'protein', 'carbohydrates', 'fat', 'userId', 'timestamp'])
          && data.keys().size() == 7
          && data.mealName is string && data.mealName.size() <= 100
          && data.calories is number
          && data.protein is number
          && data.carbohydrates is number
          && data.fat is number
          && data.userId is string
          && (data.timestamp is string || data.timestamp is timestamp);
    }

    function isValidProgress(data) {
      return data.keys().hasAll(['weight', 'bmi', 'userId', 'timestamp'])
          && data.keys().size() <= 6
          && data.weight is number
          && data.bmi is number
          && data.userId is string
          && (data.timestamp is string || data.timestamp is timestamp);
    }

    function isValidSubscription(data) {
      return data.keys().hasAll(['planName', 'transactionId', 'paymentStatus', 'purchaseDate', 'expiryDate', 'userId'])
          && data.keys().size() == 6
          && data.planName is string
          && data.transactionId is string
          && data.paymentStatus is string
          && data.userId is string;
    }

    function isValidLead(data) {
      return data.keys().hasAll(['fullName', 'email', 'selectedPlan'])
          && data.keys().size() <= 16
          && data.fullName is string && data.fullName.size() <= 100
          && (!('contactPhone' in data) || (data.contactPhone is string && (data.contactPhone.size() == 0 || (data.contactPhone.size() >= 10 && data.contactPhone.size() <= 15))))
          && data.email is string && data.email.size() <= 100
          && data.selectedPlan is string && data.selectedPlan.size() <= 100
          && (!('age' in data) || data.age is number)
          && (!('gender' in data) || data.gender is string)
          && (!('height' in data) || data.height is number)
          && (!('weight' in data) || data.weight is number)
          && (!('fitnessGoal' in data) || data.fitnessGoal is string)
          && (!('foodPreference' in data) || data.foodPreference is string)
          && (!('medicalIssue' in data) || data.medicalIssue is string)
          && (!('paymentStatus' in data) || data.paymentStatus is string)
          && (!('accessStatus' in data) || data.accessStatus is string)
          && (!('createdAt' in data) || data.createdAt is string);
    }

    // Collection Rules
    match /leads/{leadId} {
      allow create: if isValidId(leadId) && isValidLead(incoming());
      allow get: if isSignedIn() && isAdmin();
      allow list, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUserProfile(incoming(), true)
                     && incoming().role == (incoming().email == 'manish55bhagat@gmail.com' ? 'admin' : 'user');
      allow update: if isOwner(userId) && isValidUserProfile(incoming(), false) 
                     && (!('uid' in incoming()) || incoming().uid == existing().uid)
                     && (!('email' in incoming()) || incoming().email == existing().email)
                     && (!('role' in incoming()) || incoming().role == existing().role || isAdmin());
      allow delete: if false; // Profiles cannot be deleted or pruned via client directly
      
      // Subcollections
      match /workouts/{workoutId} {
        allow list, get: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidId(workoutId) && isValidWorkout(incoming()) && incoming().userId == userId;
        allow update: if isOwner(userId) && isValidId(workoutId) && isValidWorkout(incoming()) && incoming().userId == userId;
        allow delete: if isOwner(userId) && isValidId(workoutId);
      }

      match /diets/{dietId} {
        allow list, get: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidId(dietId) && isValidDiet(incoming()) && incoming().userId == userId;
        allow update: if isOwner(userId) && isValidId(dietId) && isValidDiet(incoming()) && incoming().userId == userId;
        allow delete: if isOwner(userId) && isValidId(dietId);
      }

      match /progress/{progressId} {
        allow list, get: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidId(progressId) && isValidProgress(incoming()) && incoming().userId == userId;
        allow update: if isOwner(userId) && isValidId(progressId) && isValidProgress(incoming()) && incoming().userId == userId;
        allow delete: if isOwner(userId) && isValidId(progressId);
      }

      match /subscriptions/{subId} {
        allow list, get: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidId(subId) && isValidSubscription(incoming()) && incoming().userId == userId;
        allow update: if isOwner(userId) && isValidId(subId) && isValidSubscription(incoming()) && incoming().userId == userId;
        allow delete: if false; // Subscriptions are permanent transaction receipts
      }
    }
  }
}
